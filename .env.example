# Pexels (optional for Poyo-only webhook service)
PEXELS_API_KEY=your_pexels_key

# YouTube OAuth
YOUTUBE_CLIENT_ID=your_client_id
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token

# Upload options
YOUTUBE_DEFAULT_PRIVACY=private
YOUTUBE_CATEGORY_ID=10
YOUTUBE_DEFAULT_LANGUAGE=en
PUBLISH_AT_ISO=
UPLOAD_ENABLED=true
DATABASE_URL=
N8N_WEBHOOK_URL=

# Content targeting
CONTENT_TAGS=nature,surf,ocean,sunset
PEXELS_PER_PAGE=30
PEXELS_PAGES_PER_TAG=2
TARGET_DURATION_MIN=30
TARGET_WIDTH=1920
TARGET_HEIGHT=1080
FPS=30
MAX_CLIPS_PER_RUN=20
MIN_CLIP_SECONDS=5
MAX_RECENT_TRACK_LOOKBACK=10
MAX_RECENT_CLIP_LOOKBACK=100
CLEANUP_TEMP_AFTER_RUN=true
KEEP_FINAL_OUTPUT=false
RENDER_PRESET=veryfast
RENDER_CRF=23
USE_LOCAL_VIDEOS_ONLY=false
LOCAL_VIDEOS_FALLBACK_TO_PEXELS=true
RUN_MODE=oneshot
TRIGGER_API_KEY=
NO_REPEAT_CLIPS_IN_SINGLE_VIDEO=false
ALLOW_SHORTER_UNIQUE_VIDEO=true
MATCH_VIDEO_DURATION_TO_TRACK=false

# TikTok auto-cuts from the rendered long video
TIKTOK_CUTS_ENABLED=false
TIKTOK_CLIPS_PER_RUN=3
TIKTOK_CLIP_SECONDS=30
TIKTOK_WIDTH=1080
TIKTOK_HEIGHT=1920
# Optional override; defaults to data/tiktok
TIKTOK_OUTPUT_DIR=

# Telegram delivery for generated TikTok clips
TELEGRAM_SEND_TIKTOK=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Poyo Seedance video generation (optional)
POYO_SEEDANCE_API_KEY=
POYO_SEEDANCE_API_BASE_URL=https://api.poyo.ai
POYO_SEEDANCE_GENERATE_PATH=/api/generate/submit
POYO_SEEDANCE_STATUS_PATH_TEMPLATE=/api/generate/status
POYO_SEEDANCE_DOWNLOAD_URL_FIELD=data.video_url
POYO_SEEDANCE_ID_FIELD=data.task_id
POYO_SEEDANCE_STATUS_FIELD=data.status
POYO_SEEDANCE_READY_STATUSES=completed,succeeded,ready
POYO_SEEDANCE_FAILED_STATUSES=failed,error,cancelled
POYO_SEEDANCE_POLL_INTERVAL_SECONDS=5
POYO_SEEDANCE_MAX_WAIT_SECONDS=600
