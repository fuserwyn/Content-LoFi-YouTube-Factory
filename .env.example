# Pexels
PEXELS_API_KEY=your_pexels_key

# YouTube OAuth
YOUTUBE_CLIENT_ID=your_client_id
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token

# Upload options
YOUTUBE_DEFAULT_PRIVACY=private
YOUTUBE_CATEGORY_ID=10
YOUTUBE_DEFAULT_LANGUAGE=en
PUBLISH_AT_ISO=
UPLOAD_ENABLED=true
DATABASE_URL=
N8N_WEBHOOK_URL=

# Content targeting
CONTENT_TAGS=nature,surf,ocean,sunset
PEXELS_PER_PAGE=30
PEXELS_PAGES_PER_TAG=2
TARGET_DURATION_MIN=30
TARGET_WIDTH=1920
TARGET_HEIGHT=1080
FPS=30
MAX_CLIPS_PER_RUN=20
MIN_CLIP_SECONDS=5
MAX_RECENT_TRACK_LOOKBACK=10
MAX_RECENT_CLIP_LOOKBACK=100
CLEANUP_TEMP_AFTER_RUN=true
KEEP_FINAL_OUTPUT=false
RENDER_PRESET=veryfast
RENDER_CRF=23
USE_LOCAL_VIDEOS_ONLY=false
LOCAL_VIDEOS_FALLBACK_TO_PEXELS=true
RUN_MODE=oneshot
TRIGGER_API_KEY=
